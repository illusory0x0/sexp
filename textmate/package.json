        "language": "textmate",
        "scopeName": "source.textmate",
        "path": "syntax.json"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.108.0",
    "@vscode/vsce": "^3.7.1"
  }
