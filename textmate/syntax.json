{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "textmate",
  "scopeName": "source.textmate",
  "patterns": [
    {
      "name": "keyword.other",
      "match": "(?<![^\\s()\\[\\]{}\"'`])(let|grammar|union|match|negative|repeat|concat|choice|surround)(?![^\\s()\\[\\]{}\"'`])"
    },
    {
      "name": "constant.numeric",
      "match": "(?<![^\\s()\\[\\]{}\"'`])\\d+(?![^\\s()\\[\\]{}\"'`])"
    },
    {
      "name": "variable.name",
      "match": "[^\\s()\\[\\]{}\"'`]+"
    },
    {
      "name": "string.quoted",
      "match": "\"[^\"]*\""
    }
  ]
}
