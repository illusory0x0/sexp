{
  "name": "textmate",
  "type": "commonjs",
  "version": "0.0.1",
  "main": "extension.js",
  "private": true,
  "license": "AGPL-3.0-only",
  "engines": {
    "vscode": "^1.108.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/illusory0x0"
  },
  "publisher": "illusory0x0",
  "author": {
    "name": "illusory0x0",
    "url": "https://github.com/illusory0x0"
  },
  "activationEvents": [],
  "icon": "assets/textmate.png",
  "contributes": {
    "languages": [
      {
        "id": "textmate",
